{
    "height": 24,
    "spacing": 4,
    "modules-left": ["sway/workspaces"],
    "modules-center": ["sway/window"],
    "modules-right": ["pulseaudio", "custom/clock", "tray"],
    "pulseaudio": {
        "on-click": "pavucontrol",
        "format-icons": {
            "alsa_output.pci-0000_00_1f.3.analog-stereo": "",
            "headphones": "",
            "handsfree": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["", ""]
        }
    },
    "clock": {
        "interval": 30,
        "format": "{:%a %b %d %H:%M}"
    },
    "custom/clock": {
        "exec": "echo $(date +'%a %b %d %H:%M')",
        "interval": 30
    },
    "tray": {
        "spacing": 10
    }
}
